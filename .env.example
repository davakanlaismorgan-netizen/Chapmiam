# =============================================================================
# Chap'miam — .env.example — VERSION RENDER/DOCKER
# =============================================================================
#
# POUR RENDER : NE PAS créer de fichier .env sur le serveur.
# Configurer chaque variable dans :
#   Render Dashboard → votre Service → Environment → Add Environment Variable
#
# POUR DÉVELOPPEMENT LOCAL :
#   1. cp .env.example .env
#   2. Remplir toutes les valeurs CHANGER_CETTE_VALEUR
#   3. chmod 640 .env
#   4. Ne jamais committer .env
#
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true

# URL complète de l'app (sans slash final)
# Render : https://chapmiam.onrender.com (ou votre domaine custom)
APP_URL=http://localhost:10000

# Clé secrète — générer avec : php -r "echo bin2hex(random_bytes(32));"
APP_KEY=CHANGER_CETTE_VALEUR

# ─── Base de données ─────────────────────────────────────────────────────────
# Option A : Variables séparées (PlanetScale, Railway, Aiven...)
DB_HOST=CHANGER_CETTE_VALEUR
DB_PORT=3306
DB_NAME=CHANGER_CETTE_VALEUR
DB_USER=CHANGER_CETTE_VALEUR
DB_PASS=CHANGER_CETTE_VALEUR
DB_CHARSET=utf8mb4

# Activer SSL pour les bases cloud (PlanetScale = obligatoire)
DB_SSL=false

# Option B : URL complète (si votre provider l'expose ainsi)
# Renseigner SOIT Option A SOIT Option B, pas les deux
# DATABASE_URL=mysql://user:pass@host:3306/dbname

# ─── Sessions ────────────────────────────────────────────────────────────────
# Durée d'inactivité en secondes (1800 = 30 min)
SESSION_LIFETIME=1800

# ─── Email ───────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USER=CHANGER_CETTE_VALEUR
MAIL_PASS=CHANGER_CETTE_VALEUR
MAIL_FROM=noreply@chapmiam.com
MAIL_FROM_NAME=Chapmiam

# ─── Paiement CinetPay ───────────────────────────────────────────────────────
CINETPAY_API_KEY=CHANGER_CETTE_VALEUR
CINETPAY_SITE_ID=CHANGER_CETTE_VALEUR
CINETPAY_ENV=TEST

# ─── Logs ────────────────────────────────────────────────────────────────────
# Sur Render : les logs vont sur stderr → visible dans Render Logs
# Niveau : debug | info | warning | error
# Production : warning
LOG_LEVEL=debug
LOG_PATH=../logs/app.log

# ─── Rate Limiter ─────────────────────────────────────────────────────────────
# Laisser vide en développement (utilise storage/ratelimit/)
# Sur Render avec disque persistant : /opt/render/project/data/ratelimit
# Sur Render sans disque (gratuit) : laisser vide (utilise /tmp, éphémère)
RATE_LIMIT_PATH=

# =============================================================================
# VALEURS DE PRODUCTION RENDER — À configurer dans le dashboard
# =============================================================================
#
#   APP_ENV=production
#   APP_DEBUG=false
#   APP_URL=https://votre-app.onrender.com
#   APP_KEY=<64 chars hex>
#
#   DB_HOST=<host fourni par PlanetScale/Railway/Aiven>
#   DB_NAME=<nom de la base>
#   DB_USER=<utilisateur dédié>
#   DB_PASS=<mot de passe fort>
#   DB_SSL=true  (si PlanetScale ou base cloud)
#
#   LOG_LEVEL=warning
#   CINETPAY_ENV=PROD
#
# =============================================================================
